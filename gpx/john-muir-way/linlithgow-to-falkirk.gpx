  <metadata>
    <name><![CDATA[Linlithgow to Falkirk - John Muir Way]]></name>
    <desc><![CDATA[Took the alternative path that goes along Union Canal instead of entering Hallglen. Also did a detour to see the Falkirk Wheel, so walked to Bonnybridge along the Clyde Canal instead of the official path.]]></desc>
    <link href="http://www.alltrails.com">
      <text>AllTrails, LLC</text>
    </link>
    <bounds minlat="55.9643" minlon="-3.79545" maxlat="55.99186" maxlon="-3.65634"/>
  </metadata>
